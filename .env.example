# Salin file ini jadi .env lalu isi dengan kredensial project Supabase kamu.
# Dapatkan di: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ...isi-anon-public-key-di-sini

# Set "false" untuk menyembunyikan menu Daftar (setelah akunmu dibuat).
# Kosong / "true" = pendaftaran masih bisa.
VITE_ALLOW_SIGNUP=true
